{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session_start_datetime.ps1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre_tool_scale_guard.ps1"
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre_tool_auth_warning.ps1"
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre_tool_main_branch_warning.ps1"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(.env*)",
      "Read(**/secrets/**)"
    ]
  }
}
